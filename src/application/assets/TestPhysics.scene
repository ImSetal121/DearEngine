Scene:
  name: TestPhysics
  main_camera_entity_name: camera
root:
  - Entity:
      name: camera
    components:
      CameraComponent:
        {}
      TransformComponent:
        position: [-8, 4, 0]
        rotation: [-18, 0, 0]
        scale: [1, 1, 1]
        space: ParentSpace
    children:
      []
  - Entity:
      name: dir_light
    components:
      TransformComponent:
        position: [0, 0, 0]
        rotation: [0, 9.375, 14]
        scale: [1, 1, 1]
        space: ParentSpace
      DirLightComponent:
        {}
    children:
      []
  - Entity:
      name: floor
    components:
      RigidBodyComponent:
